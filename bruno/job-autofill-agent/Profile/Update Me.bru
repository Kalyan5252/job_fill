meta {
  name: Update Me
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/profile/me
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
